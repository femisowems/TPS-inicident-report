# TPS Incident Report - Root gitignore

# Dependencies
node_modules/
**/node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Environment
.env
.env.*
!.env.example
!.env.*.example

# Build output
dist/
**/dist/
build/
coverage/
**/coverage/
.angular/
**/.angular/
out-tsc/
tmp/
temp/
*.tsbuildinfo

# Testing artifacts
.nyc_output/
.vitest/
playwright-report/
test-results/
cypress/videos/
cypress/screenshots/

# Tooling caches
.cache/
.eslintcache
.parcel-cache/
.turbo/
.nx/

# Editors / OS
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

# Local VS Code workspace settings (keep shared settings if desired)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Runtime files
*.pid
*.seed
*.pid.lock

# Deployment artifacts
.railway/
railway.json

# Secrets / local key material
*.pem
*.key
*.crt

# Misc
*.md.tmp
