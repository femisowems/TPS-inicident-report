{
  "name": "tps-incident-portal",
  "version": "1.0.0",
  "description": "TPS Incident Report monorepo with Angular client and NestJS API for non-emergency incident intake, triage, and status tracking.",
  "author": "Municipal Public Safety Division",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "npm@10.8.2",
  "homepage": "https://tps-incident.ssowemimo.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/femisowems/TPS-inicident-report.git"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently -n server,client -c yellow,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run start --workspace=@incident-report/client",
    "dev:server": "npm run start:dev --workspace=@incident-report/server",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm run build --workspace=@incident-report/client",
    "build:server": "npm run build --workspace=@incident-report/server",
    "start:client": "npm run start:prod --workspace=@incident-report/client",
    "start:server": "npm run start:prod --workspace=@incident-report/server",
    "test": "npm run test:client && npm run test:server",
    "test:client": "npm run test --workspace=@incident-report/client",
    "test:server": "npm run test --workspace=@incident-report/server",
    "test:server:cov": "npm run test:cov --workspace=@incident-report/server",
    "lint": "npm run lint:server",
    "lint:server": "npm run lint --workspace=@incident-report/server",
    "format:server": "npm run format --workspace=@incident-report/server",
    "clean": "rimraf node_modules client/node_modules server/node_modules client/dist server/dist client/.angular server/coverage"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
